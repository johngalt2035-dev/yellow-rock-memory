# Yellow Rock Memory — Environment Variables
# Copy this to .env and fill in your values:
#   cp .env.example .env

# ── Yellow Rock Memory (required) ──────────────────────────

# REQUIRED: API key for draft endpoint authentication
# Generate: openssl rand -hex 32
GRM_API_KEY=

# REQUIRED: Principal (system owner) identifier for MCP enforcement
# This is YOUR identifier — the system blocks this ID from being used as a contact
GRM_PRINCIPAL_ID=principal

# Optional: Log level (trace, debug, info, warn, error)
RUST_LOG=info

# ── OpenClaw Gateway (required for full-stack deployment) ──

# Gateway authentication token
# Generate: openssl rand -hex 32
# OPENCLAW_GATEWAY_TOKEN=

# AI provider API key — at least one required for OpenClaw
# XAI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Optional: Timezone (default: UTC)
# OPENCLAW_TZ=America/New_York

# Optional: Gateway port (default: 18789)
# OPENCLAW_GATEWAY_PORT=18789

# Optional: Gateway bind mode — lan, loopback, custom, tailnet, auto (default: lan)
# OPENCLAW_GATEWAY_BIND=lan

# Optional: Host directories for OpenClaw persistence (default: ./openclaw-config, ./openclaw-workspace)
# OPENCLAW_CONFIG_DIR=./openclaw-config
# OPENCLAW_WORKSPACE_DIR=./openclaw-workspace
